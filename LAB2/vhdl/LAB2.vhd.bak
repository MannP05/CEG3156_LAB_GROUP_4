-- ============================================================
-- CEG 3156 Lab 2 - Single-Cycle RISC Processor
--
-- Target   : Cyclone IV E, Quartus II 13.1
-- Datapath : 8-bit data, 32-bit instructions
-- Registers: 8 x 8-bit (3-bit addressing)
--
-- ============================================================

LIBRARY ieee;
USE ieee.std_logic_1164.ALL;

-- ============================================================
-- Entity  (matches Table 1 / Figure 8 in the lab manual exactly)
-- ============================================================
ENTITY singleCycleProc IS
    PORT(
        GClock         : IN  STD_LOGIC;
        GReset         : IN  STD_LOGIC;
        ValueSelect    : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
        MuxOut         : OUT STD_LOGIC_VECTOR(7 DOWNTO 0);
        InstructionOut : OUT STD_LOGIC_VECTOR(31 DOWNTO 0);
        BranchOut      : OUT STD_LOGIC;
        ZeroOut        : OUT STD_LOGIC;
        MemWriteOut    : OUT STD_LOGIC;
        RegWriteOut    : OUT STD_LOGIC
    );
END singleCycleProc;

-- ============================================================
-- Architecture
-- ============================================================
ARCHITECTURE structural OF singleCycleProc IS

    -- ==========================================================
    -- COMPONENT DECLARATIONS
    -- ==========================================================

    -- PC register: 8-bit loadable register with synchronous reset
    COMPONENT pc_reg IS
        PORT(
            i_clock : IN  STD_LOGIC;
            i_reset : IN  STD_LOGIC;
            i_d     : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            o_q     : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
        );
    END COMPONENT;

    -- n-bit adder/subtractor  (i_OpFlag='0' -> pure addition)
    COMPONENT nBitAddSubUnit IS
        GENERIC(n : INTEGER := 8);
        PORT(
            i_A        : IN  STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            i_Bi       : IN  STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            i_OpFlag   : IN  STD_LOGIC;
            o_CarryOut : OUT STD_LOGIC;
            o_Sum      : OUT STD_LOGIC_VECTOR(n-1 DOWNTO 0)
        );
    END COMPONENT;

    -- Instruction Memory: LPM ROM 256 x 32
    COMPONENT instruction_memory IS
        PORT(
            address : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            clock   : IN  STD_LOGIC;
            q       : OUT STD_LOGIC_VECTOR(31 DOWNTO 0)
        );
    END COMPONENT;

    -- Main Control Unit (structural, includes Jump output)
    COMPONENT Control_Unit IS
        PORT(
            opcode   : IN  STD_LOGIC_VECTOR(5 DOWNTO 0);
            RegDst   : OUT STD_LOGIC;
            ALUSrc   : OUT STD_LOGIC;
            MemtoReg : OUT STD_LOGIC;
            RegWrite : OUT STD_LOGIC;
            MemRead  : OUT STD_LOGIC;
            MemWrite : OUT STD_LOGIC;
            Branch   : OUT STD_LOGIC;
            Jump     : OUT STD_LOGIC;
            ALUOp    : OUT STD_LOGIC_VECTOR(1 DOWNTO 0)
        );
    END COMPONENT;

    -- n-bit 2-to-1 multiplexer
    -- Instantiated at n=3 (RegDst) and n=8 (all datapath / output mux muxes)
    COMPONENT nBitMux2to1 IS
        GENERIC(n : INTEGER := 4);
        PORT(
            i_sel      : IN  STD_LOGIC;
            i_d0, i_d1 : IN  STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            o_q        : OUT STD_LOGIC_VECTOR(n-1 DOWNTO 0)
        );
    END COMPONENT;

    -- Register File: 8 x 8-bit, 3-bit addressing
    COMPONENT register_file IS
        PORT(
            clock      : IN  STD_LOGIC;
            reset      : IN  STD_LOGIC;
            RegWrite   : IN  STD_LOGIC;
            read_reg1  : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
            read_reg2  : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
            write_reg  : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
            write_data : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            read_data1 : OUT STD_LOGIC_VECTOR(7 DOWNTO 0);
            read_data2 : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
        );
    END COMPONENT;

    -- Sign Extension: 16-bit immediate -> 8-bit  (CORRECTED: o(j) <= i(j))
    COMPONENT sign_extended IS
        PORT(
            i : IN  STD_LOGIC_VECTOR(15 DOWNTO 0);
            o : OUT STD_LOGIC_VECTOR(7  DOWNTO 0)
        );
    END COMPONENT;

    -- ALU Control
    COMPONENT ALU_control IS
        PORT(
            ALU_Op    : IN  STD_LOGIC_VECTOR(1 DOWNTO 0);
            funct     : IN  STD_LOGIC_VECTOR(5 DOWNTO 0);
            Operation : OUT STD_LOGIC_VECTOR(2 DOWNTO 0)
        );
    END COMPONENT;

    -- 8-bit ALU
    COMPONENT nbit_ALU IS
        GENERIC(n : INTEGER := 8);
        PORT(
            i_A          : IN  STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            i_B          : IN  STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            i_ALUControl : IN  STD_LOGIC_VECTOR(2 DOWNTO 0);
            o_ALUResult  : OUT STD_LOGIC_VECTOR(n-1 DOWNTO 0);
            o_Zero       : OUT STD_LOGIC
        );
    END COMPONENT;

    -- Data Memory: LPM RAM DQ 256 x 8
    COMPONENT data_memory IS
        PORT(
            address : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            clock   : IN  STD_LOGIC;
            data    : IN  STD_LOGIC_VECTOR(7 DOWNTO 0);
            wren    : IN  STD_LOGIC;
            q       : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
        );
    END COMPONENT;

    -- ==========================================================
    -- INTERNAL SIGNALS
    -- ==========================================================

    -- PC / Fetch
    SIGNAL pc_current    : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL pc_plus4      : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL pc_branch_out : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL pc_next       : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Instruction
    SIGNAL instruction   : STD_LOGIC_VECTOR(31 DOWNTO 0);
    -- Field layout (8-register subset):
    --   opcode    = instruction(31:26)
    --   rs[2:0]   = instruction(23:21)
    --   rt[2:0]   = instruction(18:16)
    --   rd[2:0]   = instruction(13:11)
    --   funct     = instruction(5:0)
    --   immediate = instruction(15:0)

    -- Control signals
    SIGNAL ctrl_RegDst   : STD_LOGIC;
    SIGNAL ctrl_ALUSrc   : STD_LOGIC;
    SIGNAL ctrl_MemtoReg : STD_LOGIC;
    SIGNAL ctrl_RegWrite : STD_LOGIC;
    SIGNAL ctrl_MemRead  : STD_LOGIC;
    SIGNAL ctrl_MemWrite : STD_LOGIC;
    SIGNAL ctrl_Branch   : STD_LOGIC;
    SIGNAL ctrl_Jump     : STD_LOGIC;
    SIGNAL ctrl_ALUOp    : STD_LOGIC_VECTOR(1 DOWNTO 0);

    -- Branch taken: single AND gate (ctrl_Branch AND alu_zero)
    SIGNAL take_branch   : STD_LOGIC;

    -- Register file
    SIGNAL reg_write_addr : STD_LOGIC_VECTOR(2 DOWNTO 0);
    SIGNAL read_data1     : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL read_data2     : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL reg_write_data : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Sign extension
    SIGNAL sign_ext_out   : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- ALU
    SIGNAL alu_ctrl       : STD_LOGIC_VECTOR(2 DOWNTO 0);
    SIGNAL alu_b_in       : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL alu_result     : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL alu_zero       : STD_LOGIC;

    -- Data memory
    SIGNAL mem_read_data  : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Branch offset: sign_ext_out[5:0] & "00"  (wired left-shift by 2)
    SIGNAL branch_offset  : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL branch_target  : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Jump address: instruction[5:0] & "00"  (wired left-shift by 2)
    SIGNAL jump_addr      : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Carry-outs (nBitAddSubUnit port required, otherwise unused)
    SIGNAL carry_pc4      : STD_LOGIC;
    SIGNAL carry_branch   : STD_LOGIC;

    -- --------------------------------------------------------
    -- Output mux intermediate signals
    -- Table 2 requires an 8-input mux for ValueSelect[2:0].
    -- Built as a balanced tree of three nBitMux2to1 stages.
    --
    -- ctrl_info packs the control output for ValueSelect = 1xx:
    --   bit 7 : '0'
    --   bit 6 : RegDst
    --   bit 5 : Jump
    --   bit 4 : MemRead
    --   bit 3 : MemtoReg
    --   bit 2 : ALUOp(1)
    --   bit 1 : ALUOp(0)
    --   bit 0 : ALUSrc
    -- --------------------------------------------------------
    SIGNAL ctrl_info      : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Stage 1: select on ValueSelect(0)  -- pairs (0,1), (2,3), (4,5), (6,7)
    --   mux_s1_01 : PC        vs ALU result
    --   mux_s1_23 : ReadData1 vs ReadData2
    --   mux_s1_45 : WriteData vs ctrl_info
    --   mux_s1_67 : ctrl_info vs ctrl_info  (101/110/111 all same)
    SIGNAL mux_s1_01      : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL mux_s1_23      : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL mux_s1_45      : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL mux_s1_67      : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Stage 2: select on ValueSelect(1)  -- pairs (01,23), (45,67)
    SIGNAL mux_s2_0123    : STD_LOGIC_VECTOR(7 DOWNTO 0);
    SIGNAL mux_s2_4567    : STD_LOGIC_VECTOR(7 DOWNTO 0);

    -- Stage 3: select on ValueSelect(2)  -- final output
    -- (output directly drives MuxOut via port map)

BEGIN

    -- ==========================================================
    -- FETCH STAGE
    -- ==========================================================

    U_PC : pc_reg
        PORT MAP(
            i_clock => GClock,
            i_reset => GReset,
            i_d     => pc_next,
            o_q     => pc_current
        );

    U_PC_ADD : nBitAddSubUnit
        GENERIC MAP(n => 8)
        PORT MAP(
            i_A        => pc_current,
            i_Bi       => x"04",
            i_OpFlag   => '0',
            o_CarryOut => carry_pc4,
            o_Sum      => pc_plus4
        );

    U_IMEM : instruction_memory
        PORT MAP(
            address => pc_current,
            clock   => GClock,
            q       => instruction
        );

    -- Wire: InstructionOut is a direct copy of the instruction bus
    InstructionOut <= instruction;

    -- ==========================================================
    -- DECODE STAGE
    -- ==========================================================

    U_CTRL : Control_Unit
        PORT MAP(
            opcode   => instruction(31 DOWNTO 26),
            RegDst   => ctrl_RegDst,
            ALUSrc   => ctrl_ALUSrc,
            MemtoReg => ctrl_MemtoReg,
            RegWrite => ctrl_RegWrite,
            MemRead  => ctrl_MemRead,
            MemWrite => ctrl_MemWrite,
            Branch   => ctrl_Branch,
            Jump     => ctrl_Jump,
            ALUOp    => ctrl_ALUOp
        );

    -- RegDst mux [3-bit]:
    --   '0' -> rt = instruction[18:16]  (I-type destination)
    --   '1' -> rd = instruction[13:11]  (R-type destination)
    U_MUX_REGDST : nBitMux2to1
        GENERIC MAP(n => 3)
        PORT MAP(
            i_sel => ctrl_RegDst,
            i_d0  => instruction(18 DOWNTO 16),
            i_d1  => instruction(13 DOWNTO 11),
            o_q   => reg_write_addr
        );

    U_REGFILE : register_file
        PORT MAP(
            clock      => GClock,
            reset      => GReset,
            RegWrite   => ctrl_RegWrite,
            read_reg1  => instruction(23 DOWNTO 21),
            read_reg2  => instruction(18 DOWNTO 16),
            write_reg  => reg_write_addr,
            write_data => reg_write_data,
            read_data1 => read_data1,
            read_data2 => read_data2
        );

    U_SIGN_EXT : sign_extended
        PORT MAP(
            i => instruction(15 DOWNTO 0),
            o => sign_ext_out
        );

    -- ==========================================================
    -- EXECUTE STAGE
    -- ==========================================================

    U_ALU_CTRL : ALU_control
        PORT MAP(
            ALU_Op    => ctrl_ALUOp,
            funct     => instruction(5 DOWNTO 0),
            Operation => alu_ctrl
        );

    -- ALUSrc mux [8-bit]:
    --   '0' -> read_data2   (R-type / branch)
    --   '1' -> sign_ext_out (lw / sw immediate)
    U_MUX_ALUSRC : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ctrl_ALUSrc,
            i_d0  => read_data2,
            i_d1  => sign_ext_out,
            o_q   => alu_b_in
        );

    U_ALU : nbit_ALU
        GENERIC MAP(n => 8)
        PORT MAP(
            i_A          => read_data1,
            i_B          => alu_b_in,
            i_ALUControl => alu_ctrl,
            o_ALUResult  => alu_result,
            o_Zero       => alu_zero
        );

    -- ==========================================================
    -- MEMORY STAGE
    -- ==========================================================

    U_DMEM : data_memory
        PORT MAP(
            address => alu_result,
            clock   => GClock,
            data    => read_data2,
            wren    => ctrl_MemWrite,
            q       => mem_read_data
        );

    -- ==========================================================
    -- WRITE-BACK STAGE
    -- ==========================================================

    -- MemtoReg mux [8-bit]:
    --   '0' -> alu_result    (R-type)
    --   '1' -> mem_read_data (lw)
    U_MUX_MEMTOREG : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ctrl_MemtoReg,
            i_d0  => alu_result,
            i_d1  => mem_read_data,
            o_q   => reg_write_data
        );

    -- ==========================================================
    -- BRANCH AND JUMP LOGIC
    -- All wiring below is structural (wire connections and single gates)
    -- ==========================================================

    -- Branch offset = sign_ext_out[5:0] & "00"
    -- This is a wired left-shift-by-2: tie low two bits to GND,
    -- connect upper 6 bits directly from sign_ext_out.
    branch_offset(0) <= '0';
    branch_offset(1) <= '0';
    branch_offset(2) <= sign_ext_out(0);
    branch_offset(3) <= sign_ext_out(1);
    branch_offset(4) <= sign_ext_out(2);
    branch_offset(5) <= sign_ext_out(3);
    branch_offset(6) <= sign_ext_out(4);
    branch_offset(7) <= sign_ext_out(5);

    U_BRANCH_ADD : nBitAddSubUnit
        GENERIC MAP(n => 8)
        PORT MAP(
            i_A        => pc_plus4,
            i_Bi       => branch_offset,
            i_OpFlag   => '0',
            o_CarryOut => carry_branch,
            o_Sum      => branch_target
        );

    -- take_branch: single AND gate
    -- BEQ taken when ctrl_Branch='1' AND alu_zero='1'
    take_branch <= ctrl_Branch AND alu_zero;

    -- Branch mux [8-bit]:
    --   '0' -> pc_plus4      (not taken)
    --   '1' -> branch_target (taken)
    U_MUX_BRANCH : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => take_branch,
            i_d0  => pc_plus4,
            i_d1  => branch_target,
            o_q   => pc_branch_out
        );

    -- Jump address = instruction[5:0] & "00"
    -- Wired left-shift-by-2: tie low two bits to GND.
    jump_addr(0) <= '0';
    jump_addr(1) <= '0';
    jump_addr(2) <= instruction(0);
    jump_addr(3) <= instruction(1);
    jump_addr(4) <= instruction(2);
    jump_addr(5) <= instruction(3);
    jump_addr(6) <= instruction(4);
    jump_addr(7) <= instruction(5);

    -- Jump mux [8-bit]:
    --   '0' -> pc_branch_out (sequential or branch)
    --   '1' -> jump_addr     (unconditional jump)
    U_MUX_JUMP : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ctrl_Jump,
            i_d0  => pc_branch_out,
            i_d1  => jump_addr,
            o_q   => pc_next
        );

    -- ==========================================================
    -- OUTPUT MUX  (Table 2 - fully structural)
    --
    -- ValueSelect truth table:
    --   000 -> pc_current      (input 0)
    --   001 -> alu_result      (input 1)
    --   010 -> read_data1      (input 2)
    --   011 -> read_data2      (input 3)
    --   100 -> reg_write_data  (input 4)
    --   1xx -> ctrl_info       (inputs 5,6,7 - all same value)
    --
    -- Tree structure (3 stages of nBitMux2to1):
    --
    --   Stage 1: 4 muxes, select = ValueSelect(0)
    --     mux_s1_01   :  [0]=pc_current   , [1]=alu_result
    --     mux_s1_23   :  [2]=read_data1   , [3]=read_data2
    --     mux_s1_45   :  [4]=reg_wr_data  , [5]=ctrl_info
    --     mux_s1_67   :  [6]=ctrl_info    , [7]=ctrl_info
    --
    --   Stage 2: 2 muxes, select = ValueSelect(1)
    --     mux_s2_0123 :  mux_s1_01 vs mux_s1_23
    --     mux_s2_4567 :  mux_s1_45 vs mux_s1_67
    --
    --   Stage 3: 1 mux,  select = ValueSelect(2)
    --     MuxOut      :  mux_s2_0123 vs mux_s2_4567
    -- ==========================================================

    -- Build ctrl_info bus from individual control signal wires
    -- Bit assignments match Table 2: '0'&RegDst&Jump&MemRead&MemtoReg&AluOp[1:0]&AluSrc
    ctrl_info(7) <= '0';
    ctrl_info(6) <= ctrl_RegDst;
    ctrl_info(5) <= ctrl_Jump;
    ctrl_info(4) <= ctrl_MemRead;
    ctrl_info(3) <= ctrl_MemtoReg;
    ctrl_info(2) <= ctrl_ALUOp(1);
    ctrl_info(1) <= ctrl_ALUOp(0);
    ctrl_info(0) <= ctrl_ALUSrc;

    -- Stage 1
    U_OMUX_S1_01 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(0),
            i_d0  => pc_current,
            i_d1  => alu_result,
            o_q   => mux_s1_01
        );

    U_OMUX_S1_23 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(0),
            i_d0  => read_data1,
            i_d1  => read_data2,
            o_q   => mux_s1_23
        );

    U_OMUX_S1_45 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(0),
            i_d0  => reg_write_data,
            i_d1  => ctrl_info,
            o_q   => mux_s1_45
        );

    -- inputs 6 and 7 are both ctrl_info (ValueSelect = 110 and 111)
    U_OMUX_S1_67 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(0),
            i_d0  => ctrl_info,
            i_d1  => ctrl_info,
            o_q   => mux_s1_67
        );

    -- Stage 2
    U_OMUX_S2_0123 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(1),
            i_d0  => mux_s1_01,
            i_d1  => mux_s1_23,
            o_q   => mux_s2_0123
        );

    U_OMUX_S2_4567 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(1),
            i_d0  => mux_s1_45,
            i_d1  => mux_s1_67,
            o_q   => mux_s2_4567
        );

    -- Stage 3: final output
    U_OMUX_S3 : nBitMux2to1
        GENERIC MAP(n => 8)
        PORT MAP(
            i_sel => ValueSelect(2),
            i_d0  => mux_s2_0123,
            i_d1  => mux_s2_4567,
            o_q   => MuxOut
        );

    -- ==========================================================
    -- ENTITY OUTPUT PORT ASSIGNMENTS  (direct wire connections)
    -- ==========================================================
    BranchOut   <= ctrl_Branch;
    ZeroOut     <= alu_zero;
    MemWriteOut <= ctrl_MemWrite;
    RegWriteOut <= ctrl_RegWrite;

END structural;