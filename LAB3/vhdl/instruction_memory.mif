DEPTH = 256;
WIDTH = 32;
ADDRESS_RADIX = HEX;
DATA_RADIX = BIN;
CONTENT
BEGIN
-- NOP (sll $0,$0,0) as default
[00..FF]: 00000000000000000000000000000000;

-- Benchmark Program:
-- lw $2, 0($0)          $2 = mem[0] = 0x55
00: 10001100000000100000000000000000;
-- lw $3, 1($0)          $3 = mem[1] = 0xAA
01: 10001100000000110000000000000001;
-- sub $1, $2, $3        $1 = 0x55 - 0xAA = 0xAB (with borrow)
02: 00000000010000110000100000100010;
-- or $4, $1, $3         $4 = $1 | $3 = 0xFF
03: 00000000001000110010000000100101;
-- beq $1,$1,20 (uncomment to test control hazard)
-- 04: 00010000001000010000000000010100;
-- sw $4, 3($0)          mem[3] = $4 = 0xFF
04: 10101100000001000000000000000011;
-- add $1, $2, $3        $1 = 0x55 + 0xAA = 0xFF
05: 00000000010000110000100000100000;
-- sw $1, 4($0)          mem[4] = $1 = 0xFF
06: 10101100000000010000000000000100;
-- lw $2, 3($0)          $2 = mem[3] = 0xFF
07: 10001100000000100000000000000011;
-- lw $3, 4($0)          $3 = mem[4] = 0xFF
08: 10001100000000110000000000000100;
-- j 11 (address 0x0B = jump to 44 decimal)
09: 00001000000000000000000000001011;
-- beq $1,$1,-44  (loop back)
0A: 0001000000100001111111111110101;
-- beq $1,$2,-8   (test $1=$2)
0B: 0001000000100011111111111111110;
END;